{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "plugins/apple-productivity/dist",
    "rootDir": "plugins/apple-productivity/src",
    "declaration": true,
    "sourceMap": true
  },
  "include": ["plugins/apple-productivity/src/**/*.ts"],
  "exclude": ["plugins/apple-productivity/src/**/*.test.ts"]
}
