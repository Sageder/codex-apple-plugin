{
  "name": "codex-apple-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local Codex plugin for Apple Mail, Calendar, and Reminders workflows.",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:mcp && swift build --package-path plugins/apple-productivity/swift && npm run build:reminders-helper",
    "build:mcp": "esbuild plugins/apple-productivity/src/index.ts --bundle --platform=node --format=esm --target=node18 --outfile=plugins/apple-productivity/dist/index.mjs",
    "build:reminders-helper": "mkdir -p plugins/apple-productivity/dist/reminders && xcrun swiftc -framework EventKit plugins/apple-productivity/src/reminders/remindersHelper.swift -o plugins/apple-productivity/dist/reminders/reminders-helper",
    "test": "vitest run",
    "check": "npm run build && npm run test",
    "permissions:request": "npm run build && tsx plugins/apple-productivity/scripts/request-permissions.ts",
    "smoke:mail": "tsx plugins/apple-productivity/scripts/smoke-mail.ts",
    "smoke:calendar": "tsx plugins/apple-productivity/scripts/smoke-calendar.ts",
    "smoke:reminders": "tsx plugins/apple-productivity/scripts/smoke-reminders.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
