{
  "mcpServers": {
    "apple-calendar": {
      "command": "node",
      "cwd": ".",
      "args": ["./dist/index.mjs"],
      "env": {
        "APPLE_CALENDAR_WRITE_MODE": "ask",
        "APPLE_CALENDAR_MAX_BODY_CHARS": "12000",
        "APPLE_CALENDAR_HELPER_TIMEOUT_MS": "60000"
      }
    }
  }
}
